        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Signin returns 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "var data = pm.response.json();\r",
              "\r",
              "pm.test(\"Token exists\", function () {\r",
              "    pm.expect(data.token).to.not.be.undefined;\r",
              "});\r",
              "\r",
              "// Store token in environment\r",
              "pm.environment.set(\"jwt_token\", data.token);"
