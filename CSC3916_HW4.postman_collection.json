  "item": [
    {
      "name": "signup",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "pm.environment.set(\"randomUser\", \"user_\" + Math.random().toString(36).substring(2,8));\r",
              "pm.environment.set(\"randomPass\", \"pass_\" + Math.random().toString(36).substring(2,8));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Signup returns success status\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);\r",
              "});\r",
              "\r",
              "var data = pm.response.json();\r",
              "\r",
              "pm.test(\"Signup success is true\", function () {\r",
              "    pm.expect(data.success).to.eql(true);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\r\n  \"name\": \"Test User\",\r\n  \"username\": \"{{randomUser}}\",\r\n  \"password\": \"{{randomPass}}\"\r\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{base_url}}/signup",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "signup"
          ]
        }
      },
      "response": []
    },
    {
